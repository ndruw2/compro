---
import { site } from '@/config/site';

interface Props {
  /** show the role as a small line under the name */
  role?: boolean;
  size?: 'sm' | 'md';
}

const { role = false, size = 'sm' } = Astro.props;
const { name, role: roleText } = site.brand;
const initials = name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .slice(0, 2);
---

<a class={`wordmark wordmark--${size}`} href="/" aria-label={`${name}, home`}>
  <span class="wordmark__badge" aria-hidden="true">{initials}</span>
  <span class="wordmark__text">
    <span class="wordmark__name">{name}</span>
    {role && <span class="wordmark__role">{roleText}</span>}
  </span>
</a>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1;
  }
  .wordmark__badge {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.55rem;
    background: var(--grad-accent);
    color: var(--color-on-accent);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .wordmark__text {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .wordmark__name {
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: var(--text-base);
  }
  .wordmark--md .wordmark__name {
    font-size: var(--text-lg);
  }
  .wordmark__role {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.01em;
  }
</style>
