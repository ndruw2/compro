---
import { site } from '@/config/site';

interface Props {
  /** accessible label describing what the script spells */
  label?: string;
  class?: string;
}

const { label, class: className } = Astro.props;
const { nameAksara, name } = site.brand;
---

<!--
  Decorative Aksara Jawa (Javanese script) brand mark.
  Rendered with Noto Sans Javanese. aria-hidden + Latin label fallback so screen
  readers announce the Latin name, not the (draft) transliteration.
-->
<span class:list={['aksara-mark', className]} role="img" aria-label={label ?? name}>
  <span class="aksara-mark__glyphs" aria-hidden="true">{nameAksara}</span>
</span>

<style>
  .aksara-mark {
    display: inline-block;
    line-height: 1;
  }
  .aksara-mark__glyphs {
    font-family: var(--font-aksara);
    font-size: var(--aksara-size, 4rem);
    background: var(--grad-gold);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1.4;
  }
</style>
