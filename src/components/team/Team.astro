---
import { site } from '@/config/site';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="team" class="section">
  <div class="container">
    <SectionHeading eyebrow="The team" id="team-heading">
      Five founders, one standard
      <span slot="lead">
        A senior, hands-on team. The people you meet are the people who build
        your software.
      </span>
    </SectionHeading>

    <ul class="team" role="list">
      {
        site.founders.map((f, i) => (
          <li class="team__card surface" data-reveal style={`--reveal-delay: ${i * 60}ms`}>
            <span class="team__avatar" aria-hidden="true">{f.initials}</span>
            <div class="team__meta">
              <h3 class="team__name">{f.name}</h3>
              <p class="team__role">{f.role}</p>
              <p class="team__focus">{f.focus}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .team {
    margin: clamp(2.5rem, 5vw, 4rem) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .team__card {
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    transition:
      transform var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo);
  }
  .team__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-strong);
  }
  .team__avatar {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--grad-gold);
    color: oklch(20% 0.02 70);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    letter-spacing: 0.02em;
  }
  .team__name {
    font-size: var(--text-lg);
  }
  .team__role {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: 0.15rem;
  }
  .team__focus {
    color: var(--color-text-faint);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    margin-top: 0.35rem;
  }
  @media (min-width: 40rem) {
    .team {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .team {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
