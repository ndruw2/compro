---
import { site } from '@/config/site';

const { heading, body, highlights } = site.about;
const initials = site.brand.name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .slice(0, 2);
---

<section id="about" class="section">
  <div class="container about">
    <div class="about__media" data-reveal>
      <div class="about__avatar" aria-hidden="true">{initials}</div>
      <ul class="about__highlights" role="list">
        {highlights.map((h) => <li>{h}</li>)}
      </ul>
    </div>

    <div class="about__body" data-reveal style="--reveal-delay: 100ms">
      <span class="eyebrow">About</span>
      <h2 class="about__title">{heading}</h2>
      {body.map((p) => <p class="about__text">{p}</p>)}
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
  }
  .about__media {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .about__avatar {
    display: grid;
    place-items: center;
    width: clamp(6rem, 18vw, 9rem);
    aspect-ratio: 1;
    border-radius: var(--radius-xl);
    background: var(--grad-accent);
    color: var(--color-on-accent);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: var(--shadow-card);
  }
  .about__highlights {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .about__highlights li {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    padding-left: 1.25rem;
    position: relative;
  }
  .about__highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
  }
  .about__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 56ch;
  }
  .about__title {
    font-size: var(--text-2xl);
    margin-top: 0.25rem;
  }
  .about__text {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }
  @media (min-width: 52rem) {
    .about {
      grid-template-columns: 16rem 1fr;
    }
  }
</style>
