---
import { site } from '@/config/site';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="work" class="section">
  <div class="container">
    <SectionHeading eyebrow="Capabilities" id="work-heading">
      Where we make the difference
      <span slot="lead">
        A snapshot of the kinds of problems we solve. Detailed case studies
        available on request.
      </span>
    </SectionHeading>

    <div class="work">
      {
        site.work.map((w, i) => (
          <article class="work__card surface" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <span class="work__sector">{w.sector}</span>
            <h3 class="work__title">{w.title}</h3>
            <p class="work__summary">{w.summary}</p>
            <p class="work__outcome">
              <span aria-hidden="true">→</span> {w.outcome}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .work__card {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .work__card:hover {
    transform: translateY(-4px);
  }
  .work__sector {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-jade);
    font-weight: 600;
  }
  .work__title {
    font-size: var(--text-lg);
  }
  .work__summary {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    flex: 1;
  }
  .work__outcome {
    font-size: var(--text-sm);
    color: var(--color-gold);
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  @media (min-width: 48rem) {
    .work {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
