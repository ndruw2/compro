---
import { site } from '@/config/site';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="services" class="section">
  <div class="container">
    <SectionHeading eyebrow="What we do" id="services-heading">
      Software built around the way you work
      <span slot="lead">
        We don't sell off-the-shelf products. We design and build to fit your
        business process — end to end.
      </span>
    </SectionHeading>

    <div class="bento" role="list">
      {
        site.services.map((s, i) => (
          <article
            class:list={['bento__card', 'surface', `span-${s.span}`]}
            role="listitem"
            data-reveal
            style={`--reveal-delay: ${i * 70}ms`}
          >
            <span class="bento__index">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="bento__title">{s.title}</h3>
            <p class="bento__blurb">{s.blurb}</p>
            <ul class="bento__points">
              {s.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .bento {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .bento__card {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition:
      transform var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo);
  }
  .bento__card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--grad-aura);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out-expo);
    pointer-events: none;
  }
  .bento__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-strong);
  }
  .bento__card:hover::after {
    opacity: 1;
  }
  .bento__index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-gold);
    letter-spacing: 0.1em;
  }
  .bento__title {
    font-size: var(--text-xl);
  }
  .bento__blurb {
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }
  .bento__points {
    margin: auto 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1rem;
  }
  .bento__points li {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  @media (min-width: 48rem) {
    .bento {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 1fr;
    }
    .span-wide {
      grid-column: span 2;
    }
    .span-tall {
      grid-row: span 2;
    }
  }
</style>
