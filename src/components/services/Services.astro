---
import { site } from '@/config/site';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="services" class="section">
  <div class="container">
    <SectionHeading eyebrow="What I do" id="services-heading">
      Custom software & AI, built around your business
      <span slot="lead">
        I help teams ship the things clients are actually paying for in 2026,
        practical AI and software that earns its keep.
      </span>
    </SectionHeading>

    <div class="grid" role="list">
      {
        site.services.map((s, i) => (
          <article
            class="card surface"
            role="listitem"
            data-reveal
            style={`--reveal-delay: ${i * 60}ms`}
          >
            <span class="card__index">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="card__title">{s.title}</h3>
            <p class="card__blurb">{s.blurb}</p>
            <ul class="card__points">
              {s.points.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .card {
    padding: clamp(1.5rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    transition:
      transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
    border-color: var(--color-border-strong);
  }
  .card__index {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }
  .card__title {
    font-size: var(--text-xl);
  }
  .card__blurb {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    flex: 1;
  }
  .card__points {
    margin: 0;
    padding: 1rem 0 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .card__points li {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 0.3rem 0.7rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }
  @media (min-width: 40rem) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
