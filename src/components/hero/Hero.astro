---
import { site } from '@/config/site';
import Button from '../ui/Button.astro';

const waHref = `https://wa.me/${site.contact.whatsapp}`;
const { name, nameAksara, tagline, intro, locationLabel } = site.brand;
---

<section class="hero" aria-labelledby="hero-heading">
  <span class="hero__aksara" aria-hidden="true">{nameAksara}</span>
  <div class="container hero__inner">
    <span class="eyebrow" data-reveal>{locationLabel}</span>

    <h1 id="hero-heading" class="hero__title" data-reveal style="--reveal-delay: 60ms">
      <span class="hero__name">{name}</span>
      <span class="hero__line">{tagline}</span>
    </h1>

    <p class="hero__lead" data-reveal style="--reveal-delay: 140ms">{intro}</p>

    <div class="hero__actions" data-reveal style="--reveal-delay: 220ms">
      <Button href={waHref} external>Start a project</Button>
      <Button href="#services" variant="ghost">See what we do</Button>
    </div>

    <dl class="hero__stats" data-reveal style="--reveal-delay: 300ms">
      <div><dt>Bespoke</dt><dd>by default</dd></div>
      <div><dt>Process-fit</dt><dd>not template</dd></div>
      <div><dt>Long-term</dt><dd>partnership</dd></div>
    </dl>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(4rem, 2rem + 9vw, 8.5rem) var(--space-section);
    overflow: hidden;
  }
  .hero__aksara {
    position: absolute;
    top: 50%;
    right: -2%;
    transform: translateY(-50%);
    font-family: var(--font-aksara);
    font-size: clamp(12rem, 30vw, 34rem);
    line-height: 1;
    color: oklch(81% 0.13 85 / 0.05);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }
  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 56rem;
  }
  .hero__title {
    font-size: var(--text-hero);
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }
  .hero__name {
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .hero__line {
    font-size: clamp(1.5rem, 0.9rem + 2.6vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.1;
    max-width: 18ch;
  }
  .hero__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 50ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin: 1.5rem 0 0;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
    width: 100%;
  }
  .hero__stats dt {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-gold);
  }
  .hero__stats dd {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    letter-spacing: 0.02em;
  }
</style>
