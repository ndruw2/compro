---
import { site } from '@/config/site';
import Button from '../ui/Button.astro';

const waHref = `https://wa.me/${site.contact.whatsapp}`;
const { name, role, tagline, intro, locationLabel } = site.brand;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__inner">
    <span class="eyebrow" data-reveal>{locationLabel}</span>

    <h1 id="hero-heading" class="hero__title" data-reveal style="--reveal-delay: 60ms">
      {tagline}
    </h1>

    <p class="hero__lead" data-reveal style="--reveal-delay: 140ms">{intro}</p>

    <div class="hero__actions" data-reveal style="--reveal-delay: 220ms">
      <Button href={waHref} external>Start a project</Button>
      <Button href="#services" variant="ghost">See what I do</Button>
    </div>

    <p class="hero__by" data-reveal style="--reveal-delay: 300ms">
      <span class="hero__dot" aria-hidden="true"></span>
      {name} · {role}
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3.5rem, 2rem + 8vw, 7.5rem) var(--space-section);
    background:
      radial-gradient(60% 60% at 85% -10%, var(--color-accent-soft) 0%, transparent 60%),
      var(--color-bg);
  }
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 54rem;
  }
  .hero__title {
    font-size: var(--text-hero);
    font-weight: 800;
    letter-spacing: -0.03em;
    max-width: 18ch;
  }
  .hero__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }
  .hero__by {
    display: inline-flex;
    align-items: center;
    gap: 0.6ch;
    margin-top: 0.75rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-faint);
  }
  .hero__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
  }
</style>
