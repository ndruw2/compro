---
import { site } from '@/config/site';
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="process" class="section process">
  <div class="container">
    <SectionHeading eyebrow="How I work" id="process-heading">
      A clear, low-friction way of working
      <span slot="lead">
        I keep the process simple and the feedback frequent — so you always know
        where things stand.
      </span>
    </SectionHeading>

    <ol class="steps">
      {
        site.approach.map((s, i) => (
          <li class="step" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
            <span class="step__num">{s.step}</span>
            <div class="step__body">
              <h3 class="step__title">{s.title}</h3>
              <p class="step__text">{s.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process {
    background: var(--color-bg-subtle);
  }
  .steps {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1rem;
  }
  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: start;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .step:hover {
    transform: translateY(-3px);
  }
  .step__num {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.4;
  }
  .step__title {
    font-size: var(--text-lg);
    margin-bottom: 0.4rem;
  }
  .step__text {
    color: var(--color-text-muted);
    max-width: 60ch;
  }
  @media (min-width: 48rem) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
