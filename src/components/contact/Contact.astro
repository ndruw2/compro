---
import { site } from '@/config/site';
import Button from '../ui/Button.astro';

const { email, whatsapp, whatsappDisplay, socials } = site.contact;
const waHref = `https://wa.me/${whatsapp}`;
const mailHref = `mailto:${email}`;
---

<section id="contact" class="section">
  <div class="container">
    <div class="cta">
      <div class="cta__inner">
        <span class="eyebrow">Let's talk</span>
        <h2 class="cta__title">
          Have a process worth <span class="text-accent">building around?</span>
        </h2>
        <p class="cta__lead">
          Tell me how your business runs. I'll show you what custom software and
          AI can do for it — no obligation.
        </p>

        <div class="cta__actions">
          <Button href={waHref} external>WhatsApp me</Button>
          <Button href={mailHref} variant="ghost">{email}</Button>
        </div>

        <ul class="cta__links" role="list">
          <li>
            <a href={waHref} target="_blank" rel="noopener noreferrer">{whatsappDisplay}</a>
          </li>
          {
            socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    padding: clamp(2.5rem, 6vw, 4.5rem);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(70% 120% at 90% 0%, var(--color-accent-soft) 0%, transparent 55%),
      var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
  .cta__inner {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    align-items: flex-start;
    max-width: 42rem;
  }
  .cta__title {
    font-size: var(--text-3xl);
  }
  .cta__lead {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
  }
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }
  .cta__links {
    margin: 1.5rem 0 0;
    padding: 1.5rem 0 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    border-top: 1px solid var(--color-border);
    width: 100%;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
  }
  .cta__links a {
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .cta__links a:hover {
    color: var(--color-accent);
  }
</style>
